page {
  background-color: #050510; /* 深空极黑底色 */
  color: #f8fafc;
  font-family: 'Inter', -apple-system, sans-serif;
  height: 100vh;
  overflow: hidden;
}

.app-container {
  height: 100%;
  position: relative;
  padding-top: 25px; /* 稍微上移避开刘海屏 */
}

/* 霓虹背景光效 */
.bg-glow {
  position: absolute;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  filter: blur(80px);
  z-index: -1;
  opacity: 0.5;
}
.bg-glow-1 { top: -50px; left: -50px; background: rgba(244, 63, 94, 0.35); } /* Rose */
.bg-glow-2 { bottom: 100px; right: -50px; background: rgba(139, 92, 246, 0.25); } /* Violet */

/* Tab 切换动画 */
.tab-content {
  display: none;
  padding: 10px 25px;
  height: calc(100vh - 170px);
  overflow-y: auto;
  animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.tab-content.active { display: block; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(15px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 核心毛玻璃类 */
.glass-card {
  background: rgba(30, 41, 59, 0.65);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25px;
}

.title-container { display: flex; flex-direction: column; }
.title {
  font-size: 32px;
  font-weight: 900;
  background: linear-gradient(135deg, #f43f5e, #8b5cf6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 1px;
}
.subtitle { font-size: 13px; color: #94a3b8; margin-top: 4px; text-transform: uppercase; letter-spacing: 2px;}

.status-badge {
  display: flex;
  align-items: center;
  padding: 8px 14px;
  border-radius: 30px;
  font-size: 12px;
  font-weight: bold;
}
.status-badge .dot { width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; }
.status-badge.connected { background: rgba(139, 92, 246, 0.15); color: #c4b5fd; border: 1px solid rgba(139, 92, 246, 0.3); }
.status-badge.connected .dot { background: #8b5cf6; box-shadow: 0 0 10px #8b5cf6; }
.status-badge.disconnected { background: rgba(244, 63, 94, 0.15); color: #fb7185; border: 1px solid rgba(244, 63, 94, 0.3); }
.status-badge.disconnected .dot { background: #f43f5e; }

/* 雷达光环特效 */
.status-ring-container {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 25px 0 35px 0; /* 缩小上下边距，整体上提 */
  position: relative;
}

.status-circle {
  width: 190px;
  height: 190px;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: linear-gradient(145deg, #1e293b, #0f172a);
  box-shadow: 15px 15px 40px #0a0f1c, -15px -15px 40px #141f38;
  border: 4px solid #1e293b;
  z-index: 2;
  transition: all 0.5s ease;
}

.status-icon { font-size: 50px; margin-bottom: 15px; }
.status-ring--1 .pulse-ring { border-color: #475569; }
.status-ring-0 .pulse-ring { border-color: #8b5cf6; animation: radar-spin 8s linear infinite; }
.status-ring-1 .pulse-ring { border-color: #a855f7; animation: radar-spin 6s linear infinite; }
.status-ring-2 .pulse-ring { border-color: #d946ef; animation: pulse-ring 2s infinite; }
.status-ring-3 .pulse-ring { border-color: #f43f5e; animation: pulse-alert 0.8s infinite; box-shadow: 0 0 40px rgba(244, 63, 94, 0.4); }

/* 按钮及交互 */
.btn-container { margin-top: 10px; display: flex; justify-content: center; margin-bottom: 25px; }

@keyframes shake {
  0% { transform: translateX(0); } 25% { transform: translateX(-4px); }
  50% { transform: translateX(4px); } 75% { transform: translateX(-4px); }
  100% { transform: translateX(0); }
}

.pulse-ring {
  position: absolute;
  width: 190px;
  height: 190px;
  border-radius: 50%;
  background: transparent;
  z-index: 1;
}

@keyframes pulse-red {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(1.6); opacity: 0; }
}

/* 日志面板 */
.card { padding: 20px 25px; margin-bottom: 25px; }
.card-title { font-size: 15px; font-weight: 700; margin-bottom: 15px; display: block; color: #cbd5e1; text-transform: uppercase; letter-spacing: 1px;}
.log-list { height: 190px; /* 增加日志显示区域的高度 */ }
.log-item { display: flex; margin-bottom: 14px; font-size: 13px; }
.log-time { color: #64748b; width: 70px; flex-shrink: 0; font-family: monospace; }
.log-msg { color: #e2e8f0; flex: 1; }

/* 悬浮式导航栏 (Floating TabBar) */
.floating-tabbar {
  position: absolute;
  bottom: 30px;
  left: 30px;
  right: 30px;
  height: 75px;
  display: flex;
  justify-content: space-around;
  align-items: center;
  border-radius: 40px; /* 胶囊形状 */
  z-index: 100;
  padding: 0 10px;
}

.tab-item {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  flex: 1; color: #64748b; transition: all 0.3s;
}
.tab-active { color: #f43f5e; transform: translateY(-2px); }
.tab-icon { font-size: 24px; margin-bottom: 4px; filter: grayscale(100%); }
.tab-active .tab-icon { filter: none; text-shadow: 0 0 15px rgba(244, 63, 94, 0.5); }
.tab-text { font-size: 11px; font-weight: bold; letter-spacing: 1px; }

/* 设置面板专属样式 */
.setting-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  font-weight: 600; font-size: 15px;
}
.setting-item text { font-size: 15px; font-weight: 500; }
.setting-input { text-align: right; color: #f43f5e; font-family: monospace; font-size: 14px; }

.btn-primary {
  background: rgba(139, 92, 246, 0.2);
  color: #c4b5fd;
  border: 1px solid rgba(139, 92, 246, 0.4);
  border-radius: 12px;
  padding: 12px;
  font-weight: bold;
  letter-spacing: 1px;
  box-shadow: 0 8px 20px rgba(16, 185, 129, 0.4);
  padding: 12px 0;
  transition: all 0.2s;
}
.btn-primary:active { transform: scale(0.96); }
